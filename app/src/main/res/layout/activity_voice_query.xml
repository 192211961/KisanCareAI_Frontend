<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#5C4D4A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:layout_toEndOf="@id/btn_back"
            android:text="Speech to Text"
            android:textColor="#5C4D4A"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintTop_toBottomOf="@id/header">

        <!-- Outer Mic Container (Light Pink) -->
        <FrameLayout
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:background="@drawable/bg_mic_outer_ripple">

            <!-- Inner Mic Container (Dark Pink) -->
            <FrameLayout
                android:id="@+id/btn_mic"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_mic_inner_circle"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <ImageView
                    android:id="@+id/mic_icon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mic"
                    app:tint="@color/white" />
            </FrameLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Listening..."
            android:textColor="#3E2723"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Speak clearly into your microphone"
            android:textColor="#8D8D8D"
            android:textSize="16sp" />

        <!-- Progress Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_dot_active" />

            <View
                android:id="@+id/dot2"
                android:layout_width="12dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_dot_inactive" />

            <View
                android:id="@+id/dot3"
                android:layout_width="12dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_dot_inactive" />

            <View
                android:id="@+id/dot4"
                android:layout_width="12dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_dot_inactive" />

            <View
                android:id="@+id/dot5"
                android:layout_width="12dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_inactive" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_spoken_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp"
            android:gravity="center"
            android:textColor="#5C4D4A"
            android:textSize="18sp"
            android:textStyle="italic"
            android:visibility="invisible"
            android:text="Spoken text here" />

    </LinearLayout>

    <!-- Bottom Action Button -->
    <FrameLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btn_record_again"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="40dp"
            android:src="@drawable/ic_refresh"
            app:tint="@color/black" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
