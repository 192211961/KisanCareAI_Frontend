<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/rate_experience"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title Info Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_blue_info_box"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_message"
                    app:tint="@color/vibrant_green" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/share_feedback_title"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/feedback_help_desc"
                        android:textColor="@color/grey"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/how_rate_experience"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/tap_star_rate"
                android:textColor="@color/grey"
                android:textSize="14sp"
                android:gravity="center" />

            <!-- Stars Bar -->
            <LinearLayout
                android:id="@+id/star_rating_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_star_outline" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_star_outline" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_star_outline" />

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_star_outline" />

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_star_outline" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/tell_us_more"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/et_feedback"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_edittext_curved"
                android:gravity="top"
                android:hint="@string/feedback_hint"
                android:padding="16dp"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/aspect_rating_title"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:gravity="center" />

            <!-- Aspect Chips -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <TextView
                    android:id="@+id/chip_ai_accuracy"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_aspect_chip"
                    android:gravity="center"
                    android:text="@string/ai_accuracy"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_app_usability"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_aspect_chip"
                    android:gravity="center"
                    android:text="@string/app_usability"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_response_speed"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_aspect_chip"
                    android:gravity="center"
                    android:text="@string/response_speed"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_overall"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_aspect_chip"
                    android:gravity="center"
                    android:text="@string/overall_experience"
                    android:textColor="@color/black"
                    android:textSize="14sp" />
            </GridLayout>

            <Button
                android:id="@+id/btn_submit_feedback"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="#D1D5DB"
                android:enabled="false"
                android:text="@string/submit_feedback"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/btn_skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp"
                android:padding="12dp"
                android:text="@string/skip_for_now"
                android:textColor="@color/grey"
                android:textSize="16sp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
